# AI provider: gemini or openrouter
AI_PROVIDER=openrouter

# OpenRouter API Key
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Optional: override the main model with a rolling alias that always uses the
# latest Flash (higher quality, higher cost — $1.50/$9.00 per 1M tokens):
# OPENROUTER_MODEL=~google/gemini-flash-latest

# Optional: use Claude Haiku for better structured JSON extraction:
# OPENROUTER_MODEL=~anthropic/claude-haiku-latest

# Optional specialised model for audio transcription (defaults to voxtral-small).
# OpenRouter has mistralai/voxtral-small-24b-2507 built for audio — much cheaper
# per audio-token than routing through a general-purpose multimodal model.
# Set to empty to fall back to OPENROUTER_MODEL for transcription too.
# For a FREE alternative:
# OPENROUTER_TRANSCRIPTION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://promapper.app
OPENROUTER_SITE_NAME=ProMapper

# Optional Gemini fallback (set AI_PROVIDER=gemini to use this)
# Get your key from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# Required shared secret for calling server-side AI routes
API_AUTH_TOKEN=replace-me

# Comma-separated list of origins allowed to hit the API routes
ALLOWED_ORIGINS=http://localhost:8003

# Simple in-memory rate limiter (requests per window & window in ms)
API_RATE_LIMIT=60
API_RATE_WINDOW_MS=60000

# Session + cookie controls
# 4 hours in milliseconds
API_SESSION_TTL_MS=14400000
# Set to true in production when served over HTTPS
API_COOKIE_SECURE=false

# Optional durable share store.
# If unset, /api/share uses an in-process memory store for local development.
# Apply supabase/migrations/20260610000000_conversation_shares.sql first.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Gemini upload cleanup retries, only used when AI_PROVIDER=gemini
# GEMINI_DELETE_RETRIES=3
# GEMINI_DELETE_RETRY_DELAY_MS=2000
